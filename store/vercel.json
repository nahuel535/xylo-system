{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/producto/:id", "destination": "/api/producto/:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/producto/[id].js": {
      "includeFiles": "dist/index.html"
    }
  }
}
